# Backend Configuration
NODE_ENV=development
PORT=5000

# Frontend URL (used for CORS and OAuth redirects)
FRONTEND_URL=http://localhost:3000

# Session/Cookie secret (CHANGE THIS IN PRODUCTION)
COOKIE_KEY=change-me-to-a-random-secret

# Google OAuth (optional - auth is bypassed if not set)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Database (leave empty for SQLite default; set for PostgreSQL in production)
# DATABASE_URL=postgresql://user:password@localhost/bugbounty

# Socket.IO
SOCKET_URL=http://localhost:5000

# Frontend Configuration (used by React app)
REACT_APP_API_URL=http://localhost:5000/api
REACT_APP_SOCKET_URL=http://localhost:5000
