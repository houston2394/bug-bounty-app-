# ─────────────────────────────────────────────────────────────────────────────
# Bug Bounty App – Environment Configuration
# Copy this file to .env and fill in the values.
# Never commit your .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# Public URL of the frontend (used for CORS and OAuth redirect allowlist).
# For Docker Compose production: http://your-domain.com
FRONTEND_URL=http://localhost:3000

# Session secret – MUST be a long random string in production.
# Generate one with:  openssl rand -hex 32
COOKIE_KEY=change-me-to-a-random-secret

# ── Google OAuth (optional) ───────────────────────────────────────────────────
# Leave blank to run without authentication (development only).
# Set both values to enable Google login.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# OAuth callback URL registered in Google Cloud Console.
CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# ── Database ──────────────────────────────────────────────────────────────────
# Path to the SQLite database file (created automatically on first run).
DATABASE_PATH=./data/bugbounty.db

# ── Frontend (React build-time / dev proxy) ───────────────────────────────────
# When running behind a reverse proxy that rewrites /api and /socket.io,
# set REACT_APP_API_URL to a relative path (e.g. /api).
REACT_APP_API_URL=http://localhost:5000/api
REACT_APP_SOCKET_URL=http://localhost:5000

# ── Docker Compose only ───────────────────────────────────────────────────────
# These variables are read by docker-compose.yml at runtime.
# REACT_APP_API_URL and REACT_APP_SOCKET_URL are also passed as build args
# to the frontend image, so set them here before running `docker compose build`.
